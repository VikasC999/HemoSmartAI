# ---- Cell 1: Install/Import ----
# !pip install tensorflow scikit-learn pandas numpy matplotlib -q

import pandas as pd
import numpy as np
import pickle
import matplotlib.pyplot as plt
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout

# ---- Cell 2: Upload and load data ----
# from google.colab import files
# uploaded = files.upload()   # select blood_demand.csv from your laptop

data = pd.read_csv("blood_demand.csv")
data["ds"] = pd.to_datetime(data["ds"])
print("Loaded:", data.shape)

# ---- Cell 3: Preprocess ----
SEQ_LENGTH = 30  # use the last 30 days to predict the next day

scaler = MinMaxScaler()
scaled = scaler.fit_transform(data[["y"]].values)

def create_sequences(series, seq_length=SEQ_LENGTH):
    X, y = [], []
    for i in range(len(series) - seq_length):
        X.append(series[i:i + seq_length])
        y.append(series[i + seq_length])
    return np.array(X), np.array(y)

X, y = create_sequences(scaled)

# Hold out the last 30 sequences for evaluation (comparable to Prophet's test split)
X_train, X_test = X[:-30], X[-30:]
y_train, y_test = y[:-30], y[-30:]

print("Train shape:", X_train.shape, "Test shape:", X_test.shape)

# ---- Cell 4: Build and train LSTM ----
model = Sequential([
    LSTM(64, return_sequences=True, input_shape=(SEQ_LENGTH, 1)),
    Dropout(0.2),
    LSTM(32),
    Dropout(0.2),
    Dense(1),
])

model.compile(optimizer="adam", loss="mse")

history = model.fit(
    X_train, y_train,
    epochs=50,
    batch_size=32,
    validation_split=0.2,
    verbose=1,
)

# ---- Cell 5: Evaluate (compare against Prophet's MAE/RMSE) ----
pred_scaled = model.predict(X_test)
pred = scaler.inverse_transform(pred_scaled)
actual = scaler.inverse_transform(y_test)

mae = mean_absolute_error(actual, pred)
rmse = np.sqrt(mean_squared_error(actual, pred))
print(f"LSTM MAE:  {mae:.2f} units")
print(f"LSTM RMSE: {rmse:.2f} units")
# Copy these two numbers into your report next to Prophet's MAE/RMSE
# from models/prophet_metrics.txt for a direct comparison.

# ---- Cell 6: Plot loss curve + predictions ----
fig, axes = plt.subplots(1, 2, figsize=(14, 4))
axes[0].plot(history.history["loss"], label="train loss")
axes[0].plot(history.history["val_loss"], label="val loss")
axes[0].set_title("LSTM Training Loss")
axes[0].legend()

axes[1].plot(actual, label="actual")
axes[1].plot(pred, label="predicted")
axes[1].set_title("LSTM: Actual vs Predicted (last 30 days)")
axes[1].legend()
plt.savefig("lstm_evaluation.png", dpi=150, bbox_inches="tight")
plt.show()

# ---- Cell 7: Save model + scaler for download ----
model.save("lstm_model.h5")
with open("lstm_scaler.pkl", "wb") as f:
    pickle.dump(scaler, f)

